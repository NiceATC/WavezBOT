{
    "name": "wavez-chatbot",
    "version": "1.0.0",
    "description": "Wavez standalone chatbot with modular command system",
    "type": "module",
    "main": "index.js",
    "scripts": {
        "start": "node index.js",
        "dev": "concurrently -n web,bot -c green,cyan \"npm run dev --prefix dashboard\" \"node index.js\"",
        "dev:bot": "node --watch index.js",
        "dev:web": "npm run dev --prefix dashboard"
    },
    "dependencies": {
        "@distube/ytdl-core": "^4.16.12",
        "@napi-rs/canvas": "^0.1.60",
        "@wavezfm/api": "^0.1.4",
        "axios": "^1.13.6",
        "better-sqlite3": "^12.8.0",
        "dotenv": "^16.5.0",
        "jsonwebtoken": "^9.0.2",
        "systeminformation": "^5.23.10",
        "ws": "^8.20.0"
    },
    "devDependencies": {
        "concurrently": "^8.2.2"
    }
}
