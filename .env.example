# ── WavezBOT — secrets ───────────────────────────────────────────────────────
# ONLY credentials go here. Everything else lives in config.json.
# Copy this file to .env and fill in your values.
# NEVER commit your real .env to version control.
#
# ── Auth mode: BOT_TOKEN  (recommended) ──────────────────────────────────────
# Generate a token via the room management page or via:
#   POST /api/rooms/:roomId/bot-tokens
# with the desired permissions (read_state, read_chat, send_chat, manage_room).
# When BOT_TOKEN is set, BOT_EMAIL and BOT_PASSWORD are NOT required.
#
BOT_TOKEN=

# ── Auth mode: email + password (fallback) ────────────────────────────────────
# Used when BOT_TOKEN is not set. The bot will log in with these credentials,
# resolve the room ID, and auto-create a short-lived bot token each session.
#
BOT_EMAIL=your_bot_email_here
BOT_PASSWORD=your_bot_password_here

# Dashboard access (single password, no username)
DASHBOARD_ENABLED=true
DASHBOARD_BIND=127.0.0.1
DASHBOARD_PASSWORD=change_me
# API key used by the dashboard client
DASHBOARD_API_KEY=change_me_too
# JWT signing secret for dashboard sessions
DASHBOARD_JWT_SECRET=change_me_super_secret
# Public URL shown in !help and in the UI
DASHBOARD_PUBLIC_URL=http://localhost:3000
# Dashboard server port
DASHBOARD_PORT=3100
# Comma-separated list of allowed origins (use * to allow all)
DASHBOARD_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Token TTL (minutes)
DASHBOARD_TOKEN_TTL_MIN=720
# Max log lines kept in memory
DASHBOARD_LOG_BUFFER=300
# Allow raw SQL execution in admin DB editor (true/false)
DASHBOARD_ALLOW_SQL=false
# Allow editing command/event files from the dashboard
DASHBOARD_ALLOW_FILE_EDIT=true
# Turnstile challenge on admin login (recommended in production)
DASHBOARD_TURNSTILE_ENABLED=false
# Cloudflare Turnstile secret key (required when enabled)
DASHBOARD_TURNSTILE_SECRET=
# Optional: custom Turnstile verification endpoint
# DASHBOARD_TURNSTILE_VERIFY_URL=https://challenges.cloudflare.com/turnstile/v0/siteverify

# Login brute-force protection (all values are tunable)
# Window for counting failed login attempts (milliseconds)
DASHBOARD_AUTH_WINDOW_MS=600000
# Maximum failed attempts per window before lock
DASHBOARD_AUTH_MAX_ATTEMPTS=6
# Lockout duration after limit is reached (milliseconds)
DASHBOARD_AUTH_LOCK_MS=900000

# Optional: ImgBB uploads for profile/balance cards
IMGBB_API_KEY=your_imgbb_api_key
